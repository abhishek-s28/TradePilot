# Where the frontend reaches the backend.
# In dev with `next dev`, leave NEXT_PUBLIC_API_BASE unset and use the Next rewrite via /api.
# In Docker, set BACKEND_URL to the service name.

# Browser-side calls. Default to "/api" so the Next rewrite handles routing.
# NEXT_PUBLIC_API_BASE=/api

# WebSocket base — must be a direct URL because rewrites don't cover ws://.
# NEXT_PUBLIC_WS_BASE=ws://localhost:8000

# Server-side proxy target used by next.config.js rewrites.
BACKEND_URL=http://localhost:8000
