# ─── Application ────────────────────────────────────────────────
APP_ENV=development            # development | staging | production
APP_NAME=tradebot
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-long-random-string

# ─── Database / Cache ───────────────────────────────────────────
# For Docker Compose (default):
DATABASE_URL=postgresql+asyncpg://tradebot:tradebot@db:5432/tradebot
# For local dev with Postgres on your host:
# DATABASE_URL=postgresql+asyncpg://tradebot:tradebot@localhost:5432/tradebot
# For zero-setup local dev with no database server (testing only — single user, no concurrency):
# DATABASE_URL=sqlite+aiosqlite:///./tradebot.db
REDIS_URL=redis://redis:6379/0

# ─── Trading Mode (HARD SAFETY) ─────────────────────────────────
# Modes: research | paper | copy | semi_auto | auto
TRADING_MODE=auto
# Master kill switch. If false, NO live orders can ever be placed.
LIVE_TRADING_ENABLED=false
# Set to true ONLY after paper trading has run profitably for N days.
LIVE_TRADING_UNLOCKED=false

# ─── Market Data Provider ───────────────────────────────────────
DATA_PROVIDER=mock             # mock | yahoo | alpaca
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_DATA_FEED=iex           # iex (free) | sip (paid)
ALPACA_TRADING_PAPER=true      # true = Alpaca paper account, false = live account behind gates

# Live Alpaca routing requires live Alpaca keys above and all of these:
# TRADING_MODE=auto             # or semi_auto for manual/live-approved workflows
# LIVE_TRADING_ENABLED=true
# LIVE_TRADING_UNLOCKED=true
# BROKER=alpaca
# ALPACA_TRADING_PAPER=false

# ─── Broker ─────────────────────────────────────────────────────
BROKER=paper                   # paper | alpaca | ibkr
IBKR_HOST=127.0.0.1
IBKR_PORT=7497                 # 7497 paper, 7496 live (DO NOT USE without unlock)
IBKR_CLIENT_ID=1
IBKR_ACCOUNT=

# ─── Risk Defaults (overridable per user in DB) ─────────────────
RISK_MAX_DAILY_LOSS_USD=1500
RISK_MAX_TRADE_LOSS_USD=500
RISK_MAX_OPEN_POSITIONS=10
RISK_MAX_TRADES_PER_DAY=30
RISK_MAX_OPTION_PREMIUM_USD=500
RISK_COOLDOWN_AFTER_LOSSES=2

# ─── Auto-trade cadence/session policy ─────────────────────────
AUTO_TRADE_REGULAR_HOURS=true
AUTO_TRADE_PREMARKET=false
AUTO_TRADE_AFTERHOURS=false
AUTO_TRADE_OVERNIGHT=false
AUTO_TRADE_OPTIONS_EXTENDED_HOURS=false
AUTO_TRADE_MAX_ENTRIES_PER_CYCLE=5
AUTO_TRADE_SCAN_INTERVAL_SECONDS=60
AUTO_TRADE_EXIT_INTERVAL_SECONDS=30
SCAN_INTERVAL_SECONDS=60
EXIT_INTERVAL_SECONDS=30
MAX_ENTRIES_PER_CYCLE=5

# ─── Auto-Trader Cadence / Sessions ─────────────────────────────
AUTO_TRADE_REGULAR_HOURS=true
AUTO_TRADE_PREMARKET=false
AUTO_TRADE_AFTERHOURS=false
AUTO_TRADE_OVERNIGHT=false
AUTO_TRADE_OPTIONS_EXTENDED_HOURS=false
AUTO_TRADE_MAX_ENTRIES_PER_CYCLE=5
AUTO_TRADE_REGULAR_MIN_CONFIDENCE=0.68
AUTO_TRADE_EXTENDED_MIN_CONFIDENCE=0.78
AUTO_TRADE_OVERNIGHT_MIN_CONFIDENCE=0.85
AUTO_TRADE_SCAN_INTERVAL_SECONDS=60
AUTO_TRADE_EXIT_INTERVAL_SECONDS=30

# ─── Notifications (optional, blank disables) ───────────────────
DISCORD_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
